# Copy this file to .env and fill in real values. Never commit .env itself.

# Postgres connection string (Railway/Render/Supabase/etc. all provide this in their dashboard)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# Long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="change-me"

PORT=3000

# Set to "production" on the deployed server. Enables secure (HTTPS-only) cookies.
NODE_ENV=development
